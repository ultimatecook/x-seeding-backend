// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Influencer {
  id          Int                  @id @default(autoincrement())
  name        String
  handle      String
  followers   Int                  @default(0)
  country     String
  email       String?
  notes       String?
  archived    Boolean              @default(false)
  createdAt   DateTime             @default(now())
  seedings    Seeding[]
  savedSizes  InfluencerSavedSize[]
}

model InfluencerSavedSize {
  id            Int        @id @default(autoincrement())
  influencerId  Int
  influencer    Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  category      String     // e.g., "tops", "bottoms", "shoes", "dresses"
  size          String     // e.g., "XS", "S", "M", "L", "XL"
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([influencerId, category])
}

model Seeding {
  id                  Int              @id @default(autoincrement())
  shop                String
  influencerId        Int
  influencer          Influencer       @relation(fields: [influencerId], references: [id])
  campaignId          Int?
  campaign            Campaign?        @relation(fields: [campaignId], references: [id])
  status              String           @default("Pending")
  trackingNumber      String?
  notes               String?
  shippingAddress     String?
  totalCost           Float            @default(0)
  shopifyDraftOrderId String?
  shopifyOrderName    String?
  invoiceUrl          String?
  createdAt           DateTime         @default(now())
  products            SeedingProduct[]
}

model SeedingProduct {
  id          Int     @id @default(autoincrement())
  seedingId   Int
  seeding     Seeding @relation(fields: [seedingId], references: [id], onDelete: Cascade)
  productId   String
  variantId   String?
  productName String
  price       Float           // retail price
  cost        Float?          // cost per unit (Shopify inventoryItem.unitCost)
  imageUrl    String?
  size        String?         // selected size (e.g., "S", "M", "L") - null if not yet selected
  category    String?         // product category for size lookup (e.g., "tops", "bottoms")
}

model Campaign {
  id           Int                @id @default(autoincrement())
  shop         String
  title        String
  budget       Float?
  createdAt    DateTime           @default(now())
  products     CampaignProduct[]
  seedings     Seeding[]
}

model CampaignProduct {
  id          Int      @id @default(autoincrement())
  campaignId  Int
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  productId   String
  productName String
  imageUrl    String?
  maxUnits    Int?
}
