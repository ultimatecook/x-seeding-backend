// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AppRole {
  Owner
  Admin
  Editor
  Viewer
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model AppUser {
  id               Int              @id @default(autoincrement())
  shop             String
  shopifyUserId    String?
  email            String?
  firstName        String?
  lastName         String?
  isShopifyOwner   Boolean          @default(false)
  isShopifyStaff   Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  memberships      AppMembership[]
  preferences      UserPreference?

  @@unique([shop, shopifyUserId])
  @@unique([shop, email])
  @@index([shop])
}

model AppMembership {
  id          Int      @id @default(autoincrement())
  shop        String
  userId      Int
  user        AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        AppRole  @default(Viewer)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([shop, userId])
  @@index([shop, role])
}

model UserPreference {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique
  user           AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  highContrast   Boolean  @default(false)
  reducedMotion  Boolean  @default(false)
  fontScale      Float    @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Influencer {
  id          Int                  @id @default(autoincrement())
  shop        String               @default("")
  name        String
  handle      String
  followers   Int                  @default(0)
  country     String
  email       String?
  notes       String?
  archived    Boolean              @default(false)
  createdAt   DateTime             @default(now())
  seedings    Seeding[]
  savedSizes  InfluencerSavedSize[]

  @@index([shop])
  @@index([shop, archived])
  @@index([archived])
  @@index([handle])
}

model InfluencerSavedSize {
  id            Int        @id @default(autoincrement())
  influencerId  Int
  influencer    Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  category      String     // e.g., "tops", "bottoms", "shoes", "dresses"
  size          String     // e.g., "XS", "S", "M", "L", "XL"
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([influencerId, category])
}

enum SeedingType {
  Online
  InStore
}

model Seeding {
  id                   Int              @id @default(autoincrement())
  shop                 String
  influencerId         Int
  influencer           Influencer       @relation(fields: [influencerId], references: [id])
  campaignId           Int?
  campaign             Campaign?        @relation(fields: [campaignId], references: [id])
  seedingType          SeedingType      @default(Online)
  storeLocationId      String?          // Shopify GID of the store (in-store seedings only)
  storeLocationName    String?          // Denormalised store name for display
  status               String           @default("Pending")
  trackingNumber       String?
  notes                String?
  shippingAddress      String?
  totalCost            Float            @default(0)
  shopifyDraftOrderId  String?
  shopifyOrderName     String?
  invoiceUrl           String?
  productDiscountCode  String?          // assigned discount code for products (from pool)
  shippingDiscountCode String?          // assigned discount code for shipping (from pool)
  createdAt            DateTime         @default(now())
  products             SeedingProduct[]
  discountCodes        DiscountCode[]

  @@index([shop])
  @@index([status])
  @@index([influencerId])
  @@index([campaignId])
  @@index([createdAt])
  @@index([shop, status])
  @@index([shop, createdAt])
}

model SeedingProduct {
  id                  Int     @id @default(autoincrement())
  seedingId           Int
  seeding             Seeding @relation(fields: [seedingId], references: [id], onDelete: Cascade)
  productId           String
  variantId           String?
  productName         String
  price               Float           // retail price
  cost                Float?          // cost per unit (Shopify inventoryItem.unitCost)
  imageUrl            String?
  size                String?         // selected size (e.g., "S", "M", "L") - null if not yet selected
  category            String?         // product category for size lookup (e.g., "tops", "bottoms")
  inventoryLocationId String?         // Shopify location GID used to fulfil from
}

model PortalUser {
  id            Int       @id @default(autoincrement())
  shop          String                        // which Shopify shop they belong to
  email         String
  name          String
  passwordHash  String?                       // null until invite is accepted
  role          AppRole   @default(Viewer)
  inviteToken        String?   @unique             // one-time token for accepting invite
  inviteExpires      DateTime?
  acceptedAt         DateTime?                     // null = pending invite
  resetToken         String?   @unique             // password reset token
  resetTokenExpires  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([shop, email])
  @@index([shop])
  @@index([inviteToken])
  @@index([resetToken])
}

model ShopBilling {
  id              Int       @id @default(autoincrement())
  shop            String    @unique
  planName        String    @default("trial")   // "trial" | "basic"
  planStatus      String    @default("trial")   // "trial" | "active" | "expired"
  billingStatus   String?                        // "pending" | "active" | "cancelled" | "frozen" | "declined"
  trialStartedAt  DateTime  @default(now())
  trialEndsAt     DateTime
  shopifyChargeId String?                        // Shopify AppSubscription GID
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([shop])
  @@index([planStatus])
}

model AuditLog {
  id           Int      @id @default(autoincrement())
  shop         String
  portalUserId Int
  userName     String
  userEmail    String
  userRole     AppRole
  action       String   // e.g. "created_seeding", "deleted_influencer", "updated_status"
  entityType   String   // "seeding", "influencer", "campaign"
  entityId     Int?
  detail       String?  // human-readable description
  createdAt    DateTime @default(now())

  @@index([shop])
  @@index([createdAt])
}

model Campaign {
  id           Int                @id @default(autoincrement())
  shop         String
  title        String
  budget       Float?
  startDate    DateTime?
  endDate      DateTime?
  archived     Boolean            @default(false)
  createdAt    DateTime           @default(now())
  products     CampaignProduct[]
  seedings     Seeding[]

  @@index([shop])
  @@index([shop, archived])
}

model CampaignProduct {
  id             Int      @id @default(autoincrement())
  campaignId     Int
  campaign       Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  productId      String
  productName    String
  imageUrl       String?
  allocatedUnits Int?     // hard limit — block seeding creation when exceeded

  @@index([campaignId])
}

// ── Inventory source rules ────────────────────────────────────────────────────
// Mirrors Shopify locations; lets admins enable/disable/reorder which locations
// seedings are fulfilled from.

enum LocationType {
  Online
  Store
}

model InventoryLocation {
  id                Int          @id @default(autoincrement())
  shop              String
  shopifyLocationId String       // Shopify GID e.g. "gid://shopify/Location/12345"
  name              String
  locationType      LocationType @default(Online)
  isEnabled         Boolean      @default(true)
  priorityOrder     Int          @default(0)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@unique([shop, shopifyLocationId])
  @@index([shop, isEnabled, priorityOrder])
  @@index([shop, locationType, isEnabled])
}

// ── Discount code pools ───────────────────────────────────────────────────────
// Pre-loaded unique codes; one from each pool is assigned when a seeding is created.
enum DiscountPoolType {
  Product
  Shipping
}

enum DiscountCodeStatus {
  Available
  Assigned
  Used
}

model DiscountCode {
  id                Int                @id @default(autoincrement())
  shop              String
  poolType          DiscountPoolType
  code              String
  status            DiscountCodeStatus @default(Available)
  assignedSeedingId Int?
  assignedSeeding   Seeding?           @relation(fields: [assignedSeedingId], references: [id], onDelete: SetNull)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@unique([shop, code])
  @@index([shop, poolType, status])
  @@index([assignedSeedingId])
}
