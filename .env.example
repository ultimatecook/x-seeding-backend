# ── Shopify ───────────────────────────────────────────────────────────────────
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_APP_URL=https://www.zeedy.xyz
SCOPES=read_inventory,read_products,write_draft_orders,read_draft_orders,read_fulfillments,read_locations

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/database

# ── Portal session ────────────────────────────────────────────────────────────
PORTAL_SESSION_SECRET=a-long-random-secret-string

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Zeedy <noreply@zeedy.xyz>

# ── Billing ──────────────────────────────────────────────────────────────────
BILLING_PLAN_PRICE=29
BILLING_TRIAL_DAYS=14
BETA_MODE=true          # Set to true to grant free access during beta period

# ── Optional ──────────────────────────────────────────────────────────────────
# SHOP_CUSTOM_DOMAIN=your-custom-shop-domain
